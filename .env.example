# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
MONGODB_DB=cve_agent

# Groq (open-source LLM — get free key at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Voyage AI (embeddings — get free key at dash.voyageai.com)
VOYAGE_API_KEY=

# GitHub (for PR creation)
GITHUB_TOKEN=

# AWS Region (Lambda runtime only — no LLM calls go to AWS)
AWS_REGION=us-east-1

# Optional: NVD API key for higher rate limits
NVD_API_KEY=
